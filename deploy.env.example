# Deploy target config. Copy this file to deploy.env and edit it for your Pi.
# deploy.env is gitignored. scripts/deploy.sh sources it; values can also be
# overridden via the environment. Defaults target a stock Raspberry Pi OS setup.

PI_USER=pi
PI_HOST=raspberrypi.local
# PI_DIR defaults to /home/${PI_USER}/ir-cam if unset.
# PI_DIR=/home/pi/ir-cam
