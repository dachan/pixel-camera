# Base URL for the camera API. Copy this file to .env.local for local dev.
#
# Dev: frontend on :3000 talks to the Flask backend on :5000 (cross-origin).
NEXT_PUBLIC_API_BASE=http://localhost:5000

# Point the dev frontend at a real Pi instead:
# NEXT_PUBLIC_API_BASE=http://raspberrypi.local:5000

# Production/kiosk: leave EMPTY so the app uses a relative /api and is served
# single-origin by Flask. The deploy build sets this explicitly:
#   NEXT_PUBLIC_API_BASE= npm run build
