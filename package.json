{
  "name": "pi-xel",
  "version": "0.1.0",
  "private": true,
  "description": "Single-device Raspberry Pi camera control app (Flask + Next.js).",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "CAMERA=mock backend/.venv/bin/python backend/app.py --port 5000",
    "dev:frontend": "npm --prefix frontend run dev -- --port 4000",
    "build": "NEXT_PUBLIC_API_BASE= npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "lint:fix": "npm --prefix frontend run lint:fix",
    "format": "npm --prefix frontend run format",
    "format:check": "npm --prefix frontend run format:check"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
